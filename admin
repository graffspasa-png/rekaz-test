<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>GRAFF SPA — Admin Panel</title>
<link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500&family=Cormorant+Garamond:wght@300;400&display=swap" rel="stylesheet">
<style>
:root{
  --ink:#080807;--ink2:#0f0d0a;--ink3:#1a1713;
  --cream:#f3ede3;--w:#fff;
  --gold:#b8965a;--gold2:#c8a66a;
  --text:#17150e;--muted:#78706a;--border:#ddd5c5;
  --red:#c0392b;--green:#27ae60;--blue:#2980b9;
  --sidebar:220px;
}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
body{font-family:'Tajawal',sans-serif;background:var(--ink2);color:#fff;direction:rtl;-webkit-font-smoothing:antialiased}

/* LOGIN */
#login-screen{position:fixed;inset:0;background:var(--ink);display:flex;align-items:center;justify-content:center;z-index:999}
#login-screen.hidden{display:none}
.login-box{background:var(--ink3);border:1px solid rgba(184,150,90,.2);padding:40px 32px;width:100%;max-width:360px;text-align:center}
.login-logo{font-family:'Cormorant Garamond',serif;font-size:22px;font-weight:300;letter-spacing:.2em;color:#fff;margin-bottom:4px}
.login-logo b{color:var(--gold);font-weight:300}
.login-sub{font-size:11px;color:rgba(255,255,255,.3);letter-spacing:.12em;margin-bottom:32px}
.login-inp{width:100%;padding:12px 14px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);color:#fff;font-family:'Tajawal',sans-serif;font-size:14px;outline:none;text-align:center;letter-spacing:.08em;margin-bottom:12px;transition:border-color .15s}
.login-inp:focus{border-color:rgba(184,150,90,.4)}
.login-btn{width:100%;padding:13px;background:var(--gold);color:var(--ink);border:none;font-family:'Tajawal',sans-serif;font-size:12px;font-weight:500;letter-spacing:.14em;cursor:pointer;transition:background .15s}
.login-btn:hover{background:var(--gold2)}
.login-err{font-size:11px;color:#e74c3c;margin-top:10px;min-height:18px}

/* LAYOUT */
#app{display:none;min-height:100vh}
#app.on{display:flex}

/* SIDEBAR */
.sidebar{width:var(--sidebar);background:var(--ink);border-left:1px solid rgba(184,150,90,.1);display:flex;flex-direction:column;flex-shrink:0;position:fixed;top:0;right:0;bottom:0;overflow-y:auto;z-index:10}
.sidebar-logo{padding:22px 18px 16px;border-bottom:1px solid rgba(184,150,90,.1)}
.sidebar-logo-txt{font-family:'Cormorant Garamond',serif;font-size:16px;font-weight:300;letter-spacing:.18em;color:#fff}
.sidebar-logo-txt b{color:var(--gold);font-weight:300}
.sidebar-label{font-size:8px;letter-spacing:.22em;color:rgba(255,255,255,.28);padding:16px 18px 6px;text-transform:uppercase}
.nav-item{display:flex;align-items:center;gap:10px;padding:10px 18px;cursor:pointer;transition:all .14s;font-size:12px;color:rgba(255,255,255,.45);letter-spacing:.04em;border-right:2px solid transparent}
.nav-item:hover{color:#fff;background:rgba(255,255,255,.04)}
.nav-item.on{color:#fff;border-right-color:var(--gold);background:rgba(184,150,90,.06)}
.nav-icon{width:16px;height:16px;opacity:.6;flex-shrink:0}
.nav-item.on .nav-icon{opacity:1}
.sidebar-foot{margin-top:auto;padding:14px 18px;border-top:1px solid rgba(184,150,90,.1)}
.logout-btn{width:100%;padding:9px;background:transparent;border:1px solid rgba(255,255,255,.1);color:rgba(255,255,255,.4);font-family:'Tajawal',sans-serif;font-size:11px;cursor:pointer;transition:all .14s;letter-spacing:.08em}
.logout-btn:hover{border-color:rgba(184,150,90,.3);color:#fff}

/* MAIN */
.main{margin-right:var(--sidebar);flex:1;min-height:100vh;display:flex;flex-direction:column}
.topbar{background:var(--ink);border-bottom:1px solid rgba(184,150,90,.1);padding:0 28px;height:52px;display:flex;align-items:center;justify-content:space-between;flex-shrink:0;position:sticky;top:0;z-index:5}
.topbar-title{font-size:14px;font-weight:500;color:#fff;letter-spacing:.04em}
.save-btn{padding:8px 20px;background:var(--gold);color:var(--ink);border:none;font-family:'Tajawal',sans-serif;font-size:11px;font-weight:500;letter-spacing:.12em;cursor:pointer;transition:background .14s}
.save-btn:hover{background:var(--gold2)}
.save-btn.saving{opacity:.7;pointer-events:none}
.save-ok{font-size:11px;color:var(--green);margin-left:10px;opacity:0;transition:opacity .3s}
.save-ok.on{opacity:1}

.content{flex:1;padding:28px;overflow-y:auto;max-width:900px;width:100%}
.panel{display:none}
.panel.on{display:block;animation:fadeIn .2s ease}
@keyframes fadeIn{from{opacity:0;transform:translateY(4px)}to{opacity:1;transform:translateY(0)}}

/* CARDS */
.card{background:var(--ink3);border:1px solid rgba(255,255,255,.07);padding:22px;margin-bottom:16px}
.card-title{font-size:12px;font-weight:500;letter-spacing:.12em;color:rgba(255,255,255,.7);margin-bottom:18px;display:flex;align-items:center;gap:9px}
.card-title::after{content:'';flex:1;height:1px;background:rgba(255,255,255,.07)}

/* FORM */
.field{margin-bottom:16px}
.field label{display:block;font-size:10px;letter-spacing:.1em;color:rgba(255,255,255,.4);margin-bottom:6px}
.field input,.field select,.field textarea{width:100%;padding:10px 12px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);color:#fff;font-family:'Tajawal',sans-serif;font-size:13px;outline:none;transition:border-color .14s}
.field input:focus,.field select:focus,.field textarea:focus{border-color:rgba(184,150,90,.4)}
.field select option{background:var(--ink);color:#fff}
.field textarea{resize:vertical;min-height:80px}
.field input[type=color]{padding:4px 6px;height:36px;cursor:pointer;border-radius:0}
.field-row{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.field-row3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px}

/* TOGGLE */
.toggle-row{display:flex;align-items:center;justify-content:space-between;padding:10px 0;border-bottom:1px solid rgba(255,255,255,.05)}
.toggle-row:last-child{border:none}
.toggle-label{font-size:12px;color:rgba(255,255,255,.65)}
.toggle-sub{font-size:10px;color:rgba(255,255,255,.28);margin-top:2px}
.toggle{width:40px;height:22px;background:rgba(255,255,255,.12);border-radius:11px;cursor:pointer;position:relative;transition:background .2s;flex-shrink:0}
.toggle.on{background:var(--gold)}
.toggle::after{content:'';width:18px;height:18px;background:#fff;border-radius:50%;position:absolute;top:2px;right:2px;transition:right .2s;box-shadow:0 1px 3px rgba(0,0,0,.3)}
.toggle.on::after{right:20px}

/* SECTIONS LIST */
.sec-list{display:flex;flex-direction:column;gap:8px}
.sec-item{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);padding:13px 14px;display:flex;align-items:center;gap:12px;cursor:grab;transition:background .12s}
.sec-item:hover{background:rgba(255,255,255,.07)}
.sec-item.dragging{opacity:.5;cursor:grabbing}
.sec-drag{color:rgba(255,255,255,.2);font-size:16px;flex-shrink:0;cursor:grab}
.sec-name{flex:1;font-size:13px;color:#fff}
.sec-sub{font-size:10px;color:rgba(255,255,255,.3);margin-top:2px}
.sec-badge{font-size:9px;background:rgba(184,150,90,.15);color:var(--gold);padding:2px 8px;border-radius:20px;letter-spacing:.06em}
.sec-actions{display:flex;gap:6px}
.sec-btn{background:none;border:1px solid rgba(255,255,255,.1);color:rgba(255,255,255,.45);font-size:10px;padding:4px 10px;cursor:pointer;transition:all .13s;font-family:'Tajawal',sans-serif;letter-spacing:.06em}
.sec-btn:hover{border-color:rgba(184,150,90,.35);color:#fff}
.sec-btn.del:hover{border-color:rgba(192,57,43,.4);color:#e74c3c}

/* BUTTONS EDITOR */
.btn-item{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);padding:13px 14px;display:flex;align-items:center;gap:12px;margin-bottom:8px}
.btn-preview{padding:8px 16px;font-size:11px;letter-spacing:.1em;font-family:'Tajawal',sans-serif;cursor:default;flex-shrink:0;min-width:140px;text-align:center;transition:all .2s}
.btn-inp{flex:1;padding:8px 10px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);color:#fff;font-family:'Tajawal',sans-serif;font-size:12px;outline:none}

/* PAGES */
.page-item{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);padding:14px;margin-bottom:8px;cursor:pointer;transition:background .12s}
.page-item:hover{background:rgba(255,255,255,.07)}
.page-title-txt{font-size:13px;color:#fff;margin-bottom:3px}
.page-slug{font-size:10px;color:rgba(255,255,255,.3);font-family:monospace}
.add-btn{padding:10px 20px;background:transparent;border:1px solid rgba(184,150,90,.3);color:var(--gold);font-family:'Tajawal',sans-serif;font-size:11px;letter-spacing:.1em;cursor:pointer;transition:all .15s}
.add-btn:hover{background:rgba(184,150,90,.08)}

/* COLOR PREVIEW */
.color-preview{width:100%;height:38px;border:1px solid rgba(255,255,255,.1);margin-bottom:6px;transition:background .2s}

/* PRODUCTS GRID */
.prod-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:10px;margin-top:12px}
.prod-card{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.07);padding:12px;cursor:pointer;transition:all .13s}
.prod-card:hover,.prod-card.sel{border-color:rgba(184,150,90,.4);background:rgba(184,150,90,.06)}
.prod-name{font-size:12px;color:#fff;margin-bottom:4px}
.prod-price{font-size:11px;color:var(--gold)}
.prod-chk{width:16px;height:16px;border:1.5px solid rgba(255,255,255,.2);float:left;margin-top:2px;display:flex;align-items:center;justify-content:center;transition:all .13s}
.prod-card.sel .prod-chk{background:var(--gold);border-color:var(--gold)}

/* MODAL */
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.75);z-index:200;display:none;align-items:center;justify-content:center;padding:20px}
.modal-overlay.on{display:flex}
.modal{background:var(--ink3);border:1px solid rgba(184,150,90,.2);padding:28px;width:100%;max-width:520px;max-height:85vh;overflow-y:auto}
.modal-title{font-size:16px;font-weight:500;color:#fff;margin-bottom:20px;display:flex;align-items:center;justify-content:space-between}
.modal-close{background:none;border:none;color:rgba(255,255,255,.4);font-size:22px;cursor:pointer;padding:0 4px;line-height:1}
.modal-close:hover{color:#fff}
.modal-btns{display:flex;gap:10px;margin-top:20px;justify-content:flex-end}
.btn-primary{padding:10px 22px;background:var(--gold);color:var(--ink);border:none;font-family:'Tajawal',sans-serif;font-size:11px;font-weight:500;letter-spacing:.12em;cursor:pointer}
.btn-secondary{padding:10px 18px;background:transparent;border:1px solid rgba(255,255,255,.15);color:rgba(255,255,255,.55);font-family:'Tajawal',sans-serif;font-size:11px;cursor:pointer}

/* PAGE EDITOR */
.page-editor{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);padding:20px;margin-top:12px;display:none}
.page-editor.on{display:block}
.editor-toolbar{display:flex;gap:6px;margin-bottom:10px;flex-wrap:wrap}
.editor-btn{padding:5px 10px;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);color:rgba(255,255,255,.6);font-size:11px;cursor:pointer;transition:all .12s;font-family:'Tajawal',sans-serif}
.editor-btn:hover{background:rgba(255,255,255,.12);color:#fff}
.editor-area{width:100%;min-height:200px;padding:12px;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.08);color:#fff;font-family:'Tajawal',sans-serif;font-size:13px;outline:none;resize:vertical;line-height:1.7}

/* STATUS */
.status-dot{width:8px;height:8px;border-radius:50%;display:inline-block;margin-left:6px}
.status-dot.live{background:var(--green)}
.status-dot.off{background:rgba(255,255,255,.2)}

/* FONT PREVIEW */
.font-preview{font-size:18px;color:rgba(255,255,255,.4);margin-top:6px;padding:10px 0}

@media(max-width:768px){
  .sidebar{display:none}
  .main{margin-right:0}
  .field-row,.field-row3{grid-template-columns:1fr}
}
</style>
</head>
<body>

<!-- LOGIN -->
<div id="login-screen">
  <div class="login-box">
    <div class="login-logo">GRAFF <b>SPA</b></div>
    <div class="login-sub">ADMIN PANEL</div>
    <input class="login-inp" id="login-inp" type="password" placeholder="كلمة المرور" onkeydown="if(event.key==='Enter')doLogin()">
    <button class="login-btn" onclick="doLogin()">دخول</button>
    <div class="login-err" id="login-err"></div>
  </div>
</div>

<!-- APP -->
<div id="app">
  <!-- SIDEBAR -->
  <div class="sidebar">
    <div class="sidebar-logo"><div class="sidebar-logo-txt">GRAFF <b>SPA</b></div></div>
    <div class="sidebar-label">الإدارة</div>
    <div class="nav-item on" onclick="showPanel('overview')">
      <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
      نظرة عامة
    </div>
    <div class="nav-item" onclick="showPanel('sections')">
      <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      الأقسام والخدمات
    </div>
    <div class="nav-item" onclick="showPanel('design')">
      <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="3"/><path d="M12 2v3M12 19v3M4.22 4.22l2.12 2.12M17.66 17.66l2.12 2.12M2 12h3M19 12h3M4.22 19.78l2.12-2.12M17.66 6.34l2.12-2.12"/></svg>
      التصميم والهوية
    </div>
    <div class="nav-item" onclick="showPanel('buttons')">
      <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="7" width="20" height="10" rx="2"/><path d="M7 12h10"/></svg>
      الأزرار
    </div>
    <div class="sidebar-label">المحتوى</div>
    <div class="nav-item" onclick="showPanel('pages')">
      <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
      الصفحات
    </div>
    <div class="nav-item" onclick="showPanel('social')">
      <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
      السوشيال ميديا
    </div>
    <div class="sidebar-foot">
      <button class="logout-btn" onclick="doLogout()">تسجيل الخروج</button>
    </div>
  </div>

  <!-- MAIN -->
  <div class="main">
    <div class="topbar">
      <div class="topbar-title" id="topbar-title">نظرة عامة</div>
      <div style="display:flex;align-items:center">
        <span class="save-ok" id="save-ok">✓ تم الحفظ</span>
        <button class="save-btn" id="save-btn" onclick="saveAll()">حفظ التغييرات</button>
      </div>
    </div>

    <div class="content">

      <!-- OVERVIEW -->
      <div class="panel on" id="panel-overview">
        <div class="card">
          <div class="card-title">حالة النظام</div>
          <div class="toggle-row">
            <div><div class="toggle-label">الموقع الرئيسي</div><div class="toggle-sub">GRAFF SPA — Riyadh</div></div>
            <span><span class="status-dot live"></span></span>
          </div>
          <div class="toggle-row">
            <div><div class="toggle-label">نظام الحجز (Rekaz)</div><div class="toggle-sub" id="rekaz-status">جاري الفحص...</div></div>
            <span><span class="status-dot" id="rekaz-dot"></span></span>
          </div>
          <div class="toggle-row">
            <div><div class="toggle-label">Backend Server</div><div id="backend-url" class="toggle-sub">rekaz-test.onrender.com</div></div>
            <span><span class="status-dot live"></span></span>
          </div>
        </div>
        <div class="card">
          <div class="card-title">ملخص الإعدادات</div>
          <div id="overview-summary" style="font-size:12px;color:rgba(255,255,255,.45);line-height:2.2"></div>
        </div>
      </div>

      <!-- SECTIONS -->
      <div class="panel" id="panel-sections">
        <div class="card">
          <div class="card-title">الأقسام الرئيسية</div>
          <div class="sec-list" id="sec-list"></div>
          <button class="add-btn" style="margin-top:14px" onclick="openAddSection()">+ إضافة قسم جديد</button>
        </div>
        <div class="card">
          <div class="card-title">خدمات Rekaz (للربط)</div>
          <div style="font-size:11px;color:rgba(255,255,255,.35);margin-bottom:12px">الخدمات من Rekaz — اختاري الخدمات التي تريدين ربطها بكل قسم</div>
          <div id="rekaz-products-list" class="prod-grid"><div style="color:rgba(255,255,255,.3);font-size:12px">جاري التحميل...</div></div>
        </div>
      </div>

      <!-- DESIGN -->
      <div class="panel" id="panel-design">
        <div class="card">
          <div class="card-title">الألوان</div>
          <div class="field-row">
            <div class="field">
              <label>اللون الذهبي الأساسي</label>
              <div class="color-preview" id="cp-primary"></div>
              <input type="color" id="color-primary" oninput="updateColorPreview('primary',this.value)">
            </div>
            <div class="field">
              <label>لون الخلفية الداكنة</label>
              <div class="color-preview" id="cp-bg"></div>
              <input type="color" id="color-bg" oninput="updateColorPreview('bg',this.value)">
            </div>
          </div>
        </div>
        <div class="card">
          <div class="card-title">الخطوط</div>
          <div class="field">
            <label>خط النصوص العربية</label>
            <select id="font-arabic" onchange="updateFontPreview()">
              <option value="Tajawal">Tajawal</option>
              <option value="Cairo">Cairo</option>
              <option value="Almarai">Almarai</option>
              <option value="Noto Sans Arabic">Noto Sans Arabic</option>
              <option value="Readex Pro">Readex Pro</option>
            </select>
            <div class="font-preview" id="font-preview">مثال على النص بهذا الخط</div>
          </div>
          <div class="field">
            <label>خط العناوين الإنجليزية</label>
            <select id="font-display">
              <option value="Cormorant Garamond">Cormorant Garamond</option>
              <option value="Playfair Display">Playfair Display</option>
              <option value="EB Garamond">EB Garamond</option>
              <option value="Libre Baskerville">Libre Baskerville</option>
            </select>
          </div>
        </div>
        <div class="card">
          <div class="card-title">الهوية البصرية</div>
          <div class="field">
            <label>العبارة الرئيسية (Tagline)</label>
            <input type="text" id="tagline" placeholder="حيث تلتقي العناية بالفخامة">
          </div>
          <div class="field">
            <label>شكل الأزرار</label>
            <select id="btn-style">
              <option value="sharp">مستطيل حاد (Sharp)</option>
              <option value="rounded">مستطيل دائري (Rounded)</option>
              <option value="pill">بيضاوي (Pill)</option>
            </select>
          </div>
        </div>
      </div>

      <!-- BUTTONS -->
      <div class="panel" id="panel-buttons">
        <div class="card">
          <div class="card-title">أزرار الصفحة الرئيسية</div>
          <div id="btns-list"></div>
        </div>
      </div>

      <!-- PAGES -->
      <div class="panel" id="panel-pages">
        <div class="card">
          <div class="card-title">الصفحات</div>
          <div id="pages-list"></div>
          <button class="add-btn" style="margin-top:14px" onclick="openAddPage()">+ إضافة صفحة جديدة</button>
        </div>
        <div class="page-editor" id="page-editor">
          <div class="card-title" id="page-editor-title">تعديل الصفحة</div>
          <div class="field">
            <label>عنوان الصفحة (عربي)</label>
            <input type="text" id="page-title-ar" placeholder="مثال: بطاقات الإهداء">
          </div>
          <div class="field">
            <label>Slug (الرابط)</label>
            <input type="text" id="page-slug" placeholder="gift-cards" style="direction:ltr;text-align:left">
          </div>
          <div class="field">
            <label>المحتوى</label>
            <div class="editor-toolbar">
              <button class="editor-btn" onclick="insertTag('h2')">عنوان</button>
              <button class="editor-btn" onclick="insertTag('p')">فقرة</button>
              <button class="editor-btn" onclick="insertTag('b')">عريض</button>
              <button class="editor-btn" onclick="insertTag('br')">سطر جديد</button>
            </div>
            <textarea class="editor-area" id="page-content" placeholder="أكتبي محتوى الصفحة هنا..."></textarea>
          </div>
          <div class="field">
            <label>الصفحة مرئية</label>
            <div class="toggle" id="page-visible-toggle" onclick="this.classList.toggle('on')"></div>
          </div>
          <div style="display:flex;gap:10px;margin-top:14px">
            <button class="btn-primary" onclick="savePage()">حفظ الصفحة</button>
            <button class="btn-secondary" onclick="closePageEditor()">إلغاء</button>
          </div>
        </div>
      </div>

      <!-- SOCIAL -->
      <div class="panel" id="panel-social">
        <div class="card">
          <div class="card-title">حسابات التواصل الاجتماعي</div>
          <div class="field">
            <label>Instagram — رابط الحساب</label>
            <input type="text" id="soc-instagram" placeholder="https://instagram.com/graffspa">
          </div>
          <div class="field">
            <label>TikTok — رابط الحساب</label>
            <input type="text" id="soc-tiktok" placeholder="https://tiktok.com/@graffspa">
          </div>
          <div class="field">
            <label>Snapchat — رابط الحساب</label>
            <input type="text" id="soc-snapchat" placeholder="https://snapchat.com/add/graffspa">
          </div>
          <div class="field">
            <label>X (Twitter) — رابط الحساب</label>
            <input type="text" id="soc-twitter" placeholder="https://x.com/graffspa">
          </div>
          <div class="field">
            <label>WhatsApp — رقم الجوال (بدون +)</label>
            <input type="text" id="soc-whatsapp" placeholder="966500000000" style="direction:ltr;text-align:left">
          </div>
        </div>
      </div>

    </div><!-- /content -->
  </div><!-- /main -->
</div><!-- /app -->

<!-- ADD SECTION MODAL -->
<div class="modal-overlay" id="add-sec-modal">
  <div class="modal">
    <div class="modal-title">
      <span id="add-sec-modal-title">إضافة قسم جديد</span>
      <button class="modal-close" onclick="closeModal('add-sec-modal')">×</button>
    </div>
    <div class="field">
      <label>اسم القسم (عربي)</label>
      <input type="text" id="sec-name-ar" placeholder="مثال: الأظافر">
    </div>
    <div class="field">
      <label>اسم القسم (إنجليزي)</label>
      <input type="text" id="sec-name-en" placeholder="مثال: NAILS">
    </div>
    <div class="field">
      <label>الأقسام الفرعية (كل قسم في سطر)</label>
      <textarea id="sec-subs" placeholder="MANICURE · مناكير&#10;PEDICURE · بديكير&#10;EXTENSIONS · اكستنشن"></textarea>
    </div>
    <div class="modal-btns">
      <button class="btn-primary" onclick="saveSection()">حفظ القسم</button>
      <button class="btn-secondary" onclick="closeModal('add-sec-modal')">إلغاء</button>
    </div>
  </div>
</div>

<script>
var B = 'https://rekaz-test.onrender.com';
var TOKEN = '';
var CONFIG = {};
var editingSectionIdx = -1;
var editingPageIdx = -1;

// ── AUTH ──
function doLogin(){
  var pass = document.getElementById('login-inp').value;
  fetch(B+'/admin/login',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({password:pass})})
    .then(function(r){return r.json();})
    .then(function(d){
      if(d.success){
        TOKEN = d.token;
        document.getElementById('login-screen').classList.add('hidden');
        document.getElementById('app').classList.add('on');
        init();
      }else{
        document.getElementById('login-err').textContent = d.error || 'كلمة المرور غير صحيحة';
      }
    })
    .catch(function(){document.getElementById('login-err').textContent='خطأ في الاتصال بالسيرفر';});
}
function doLogout(){TOKEN='';location.reload();}
document.getElementById('login-inp').addEventListener('keydown',function(e){if(e.key==='Enter')doLogin();});

// ── INIT ──
function init(){
  loadConfig();
  loadRekazProducts();
  checkRekazStatus();
}

function loadConfig(){
  fetch(B+'/admin/config',{headers:{'Authorization':'Bearer '+TOKEN}})
    .then(function(r){return r.json();})
    .then(function(d){
      CONFIG = d;
      renderAll();
    });
}

function renderAll(){
  renderDesign();
  renderSections();
  renderButtons();
  renderPages();
  renderSocial();
  renderOverview();
}

// ── PANELS ──
var PANEL_TITLES = {
  overview:'نظرة عامة', sections:'الأقسام والخدمات',
  design:'التصميم والهوية', buttons:'الأزرار',
  pages:'الصفحات', social:'السوشيال ميديا'
};
function showPanel(id){
  document.querySelectorAll('.panel').forEach(function(p){p.classList.remove('on');});
  document.querySelectorAll('.nav-item').forEach(function(n){n.classList.remove('on');});
  document.getElementById('panel-'+id).classList.add('on');
  document.querySelector('[onclick="showPanel(\''+id+'\')"]').classList.add('on');
  document.getElementById('topbar-title').textContent = PANEL_TITLES[id]||id;
}

// ── SAVE ALL ──
function saveAll(){
  var btn = document.getElementById('save-btn');
  btn.textContent='جاري الحفظ...';btn.classList.add('saving');
  collectDesign();
  collectSocial();
  collectButtons();
  fetch(B+'/admin/config',{
    method:'PUT',
    headers:{'Content-Type':'application/json','Authorization':'Bearer '+TOKEN},
    body:JSON.stringify(CONFIG)
  }).then(function(r){return r.json();}).then(function(){
    btn.textContent='حفظ التغييرات';btn.classList.remove('saving');
    var ok = document.getElementById('save-ok');
    ok.classList.add('on');
    setTimeout(function(){ok.classList.remove('on');},2500);
  });
}

// ── DESIGN ──
function renderDesign(){
  var ui = CONFIG.ui || {};
  document.getElementById('color-primary').value = ui.primaryColor || '#b8965a';
  document.getElementById('color-bg').value = ui.backgroundColor || '#080807';
  document.getElementById('cp-primary').style.background = ui.primaryColor || '#b8965a';
  document.getElementById('cp-bg').style.background = ui.backgroundColor || '#080807';
  document.getElementById('tagline').value = ui.heroTagline || '';
  var fs = document.getElementById('font-arabic');
  for(var i=0;i<fs.options.length;i++) if(fs.options[i].value===ui.fontFamily) fs.selectedIndex=i;
  var fd = document.getElementById('font-display');
  for(var i=0;i<fd.options.length;i++) if(fd.options[i].value===ui.displayFont) fd.selectedIndex=i;
  var bs = document.getElementById('btn-style');
  for(var i=0;i<bs.options.length;i++) if(bs.options[i].value===ui.buttonStyle) bs.selectedIndex=i;
  updateFontPreview();
}
function updateColorPreview(type, val){
  document.getElementById('cp-'+type).style.background = val;
}
function updateFontPreview(){
  var font = document.getElementById('font-arabic').value;
  var link = document.getElementById('gfont-link');
  if(!link){link=document.createElement('link');link.id='gfont-link';link.rel='stylesheet';document.head.appendChild(link);}
  link.href='https://fonts.googleapis.com/css2?family='+encodeURIComponent(font)+':wght@400;500&display=swap';
  document.getElementById('font-preview').style.fontFamily=font;
}
function collectDesign(){
  CONFIG.ui = CONFIG.ui || {};
  CONFIG.ui.primaryColor = document.getElementById('color-primary').value;
  CONFIG.ui.backgroundColor = document.getElementById('color-bg').value;
  CONFIG.ui.heroTagline = document.getElementById('tagline').value;
  CONFIG.ui.fontFamily = document.getElementById('font-arabic').value;
  CONFIG.ui.displayFont = document.getElementById('font-display').value;
  CONFIG.ui.buttonStyle = document.getElementById('btn-style').value;
}

// ── SECTIONS ──
function renderSections(){
  var list = document.getElementById('sec-list');
  var secs = CONFIG.sections || [];
  if(!secs.length){
    list.innerHTML='<div style="font-size:12px;color:rgba(255,255,255,.3);padding:12px 0">لا توجد أقسام بعد. أضيفي أقساماً أو سيتم استخدام التصنيف التلقائي.</div>';
    return;
  }
  list.innerHTML = secs.map(function(s,i){
    return '<div class="sec-item" draggable="true" data-idx="'+i+'" ondragstart="dragStart(event,'+i+')" ondragover="dragOver(event)" ondrop="dropSec(event,'+i+')">'
      +'<span class="sec-drag">⠿</span>'
      +'<div style="flex:1"><div class="sec-name">'+s.nameAr+' <span style="color:rgba(255,255,255,.35)">/ '+s.nameEn+'</span></div>'
      +'<div class="sec-sub">'+(s.subs||[]).join(' · ')+'</div></div>'
      +'<span class="sec-badge">'+(s.visible!==false?'مرئي':'مخفي')+'</span>'
      +'<div class="sec-actions">'
      +'<button class="sec-btn" onclick="editSection('+i+')">تعديل</button>'
      +'<button class="sec-btn" onclick="toggleSectionVisibility('+i+')">'+(s.visible!==false?'إخفاء':'إظهار')+'</button>'
      +'<button class="sec-btn del" onclick="deleteSection('+i+')">حذف</button>'
      +'</div></div>';
  }).join('');
}

var dragIdx = -1;
function dragStart(e,i){dragIdx=i;e.currentTarget.classList.add('dragging');}
function dragOver(e){e.preventDefault();}
function dropSec(e,toIdx){
  e.preventDefault();
  document.querySelectorAll('.sec-item').forEach(function(el){el.classList.remove('dragging');});
  if(dragIdx<0||dragIdx===toIdx)return;
  var secs=CONFIG.sections||[];
  var moved=secs.splice(dragIdx,1)[0];
  secs.splice(toIdx,0,moved);
  CONFIG.sections=secs;
  renderSections();
}

function openAddSection(){
  editingSectionIdx=-1;
  document.getElementById('add-sec-modal-title').textContent='إضافة قسم جديد';
  document.getElementById('sec-name-ar').value='';
  document.getElementById('sec-name-en').value='';
  document.getElementById('sec-subs').value='';
  document.getElementById('add-sec-modal').classList.add('on');
}
function editSection(i){
  editingSectionIdx=i;
  var s=CONFIG.sections[i];
  document.getElementById('add-sec-modal-title').textContent='تعديل القسم';
  document.getElementById('sec-name-ar').value=s.nameAr||'';
  document.getElementById('sec-name-en').value=s.nameEn||'';
  document.getElementById('sec-subs').value=(s.subs||[]).join('\n');
  document.getElementById('add-sec-modal').classList.add('on');
}
function saveSection(){
  var s={
    nameAr:document.getElementById('sec-name-ar').value.trim(),
    nameEn:document.getElementById('sec-name-en').value.trim(),
    subs:document.getElementById('sec-subs').value.split('\n').map(function(x){return x.trim();}).filter(Boolean),
    visible:true
  };
  if(!s.nameAr)return;
  CONFIG.sections=CONFIG.sections||[];
  if(editingSectionIdx>=0) CONFIG.sections[editingSectionIdx]=s;
  else CONFIG.sections.push(s);
  renderSections();
  closeModal('add-sec-modal');
  saveAll();
}
function toggleSectionVisibility(i){
  CONFIG.sections[i].visible=!(CONFIG.sections[i].visible!==false);
  renderSections();
}
function deleteSection(i){
  if(!confirm('حذف هذا القسم؟'))return;
  CONFIG.sections.splice(i,1);
  renderSections();
  saveAll();
}

// ── REKAZ PRODUCTS ──
function loadRekazProducts(){
  fetch(B+'/admin/products',{headers:{'Authorization':'Bearer '+TOKEN}})
    .then(function(r){return r.json();})
    .then(function(d){
      var items=d.items||[];
      var html=items.map(function(p){
        var name=(p.nameAr||p.name||'').split(' - ')[0];
        return '<div class="prod-card" title="'+name+'">'
          +'<div class="prod-name">'+name.substring(0,28)+(name.length>28?'...':'')+'</div>'
          +'<div class="prod-price">SAR '+(p.amount||0)+'</div>'
          +'</div>';
      }).join('');
      document.getElementById('rekaz-products-list').innerHTML=html||'<div style="color:rgba(255,255,255,.3);font-size:12px">لا توجد منتجات</div>';
    })
    .catch(function(){document.getElementById('rekaz-products-list').innerHTML='<div style="color:#e74c3c;font-size:12px">خطأ في تحميل المنتجات</div>';});
}

// ── BUTTONS ──
function renderButtons(){
  var btns=CONFIG.buttons||[];
  var styles={'sharp':'border-radius:0','rounded':'border-radius:6px','pill':'border-radius:50px'};
  var style=styles[(CONFIG.ui||{}).buttonStyle||'sharp'];
  document.getElementById('btns-list').innerHTML=btns.map(function(b,i){
    return '<div class="btn-item">'
      +'<div class="toggle'+(b.visible!==false?' on':'')+'" onclick="toggleBtn('+i+')"></div>'
      +'<input class="btn-inp" value="'+escHtml(b.text||'')+'" onchange="updateBtnText('+i+',this.value)" placeholder="نص الزر">'
      +'<div class="btn-preview" style="background:'+(i===0?((CONFIG.ui||{}).primaryColor||'#b8965a'):'transparent')+';color:'+(i===0?'#080807':'rgba(255,255,255,.5)')+';border:1px solid '+(i===0?'transparent':'rgba(255,255,255,.15)')+';'+style+'">'+escHtml(b.text||'')+'</div>'
      +'</div>';
  }).join('');
}
function toggleBtn(i){CONFIG.buttons[i].visible=!(CONFIG.buttons[i].visible!==false);renderButtons();}
function updateBtnText(i,v){CONFIG.buttons[i].text=v;renderButtons();}
function collectButtons(){/* already updated on change */}

// ── PAGES ──
function renderPages(){
  var pages=CONFIG.pages||[];
  var list='';
  if(!pages.length) list='<div style="font-size:12px;color:rgba(255,255,255,.3);padding:8px 0">لا توجد صفحات بعد</div>';
  else list=pages.map(function(p,i){
    return '<div class="page-item" onclick="editPage('+i+')">'
      +'<div class="page-title-txt">'+escHtml(p.titleAr||'')+'</div>'
      +'<div class="page-slug">/'+escHtml(p.slug||'')+'</div>'
      +'</div>';
  }).join('');
  document.getElementById('pages-list').innerHTML=list;
}
function openAddPage(){
  editingPageIdx=-1;
  document.getElementById('page-editor-title').textContent='صفحة جديدة';
  document.getElementById('page-title-ar').value='';
  document.getElementById('page-slug').value='';
  document.getElementById('page-content').value='';
  document.getElementById('page-visible-toggle').classList.add('on');
  document.getElementById('page-editor').classList.add('on');
}
function editPage(i){
  editingPageIdx=i;
  var p=CONFIG.pages[i];
  document.getElementById('page-editor-title').textContent='تعديل: '+(p.titleAr||'');
  document.getElementById('page-title-ar').value=p.titleAr||'';
  document.getElementById('page-slug').value=p.slug||'';
  document.getElementById('page-content').value=p.content||'';
  var tog=document.getElementById('page-visible-toggle');
  p.visible!==false?tog.classList.add('on'):tog.classList.remove('on');
  document.getElementById('page-editor').classList.add('on');
}
function savePage(){
  var p={
    titleAr:document.getElementById('page-title-ar').value.trim(),
    slug:document.getElementById('page-slug').value.trim().replace(/\s+/g,'-').toLowerCase(),
    content:document.getElementById('page-content').value,
    visible:document.getElementById('page-visible-toggle').classList.contains('on')
  };
  if(!p.titleAr||!p.slug)return alert('أدخلي عنوان ورابط الصفحة');
  CONFIG.pages=CONFIG.pages||[];
  if(editingPageIdx>=0) CONFIG.pages[editingPageIdx]=p;
  else CONFIG.pages.push(p);
  renderPages();
  closePageEditor();
  saveAll();
}
function closePageEditor(){document.getElementById('page-editor').classList.remove('on');}
function insertTag(tag){
  var ta=document.getElementById('page-content');
  var start=ta.selectionStart,end=ta.selectionEnd,val=ta.value;
  var sel=val.substring(start,end)||'النص هنا';
  if(tag==='br') ta.value=val.substring(0,start)+'\n'+val.substring(end);
  else ta.value=val.substring(0,start)+'<'+tag+'>'+sel+'</'+tag+'>'+val.substring(end);
}

// ── SOCIAL ──
function renderSocial(){
  var soc=CONFIG.social||{};
  document.getElementById('soc-instagram').value=soc.instagram||'';
  document.getElementById('soc-tiktok').value=soc.tiktok||'';
  document.getElementById('soc-snapchat').value=soc.snapchat||'';
  document.getElementById('soc-twitter').value=soc.twitter||'';
  document.getElementById('soc-whatsapp').value=soc.whatsapp||'';
}
function collectSocial(){
  CONFIG.social={
    instagram:document.getElementById('soc-instagram').value.trim(),
    tiktok:document.getElementById('soc-tiktok').value.trim(),
    snapchat:document.getElementById('soc-snapchat').value.trim(),
    twitter:document.getElementById('soc-twitter').value.trim(),
    whatsapp:document.getElementById('soc-whatsapp').value.trim()
  };
}

// ── OVERVIEW ──
function renderOverview(){
  var ui=CONFIG.ui||{};
  var soc=CONFIG.social||{};
  var s=CONFIG.sections||[];
  var p=CONFIG.pages||[];
  document.getElementById('overview-summary').innerHTML=
    '<div>🎨 اللون الأساسي: <span style="color:var(--gold)">'+escHtml(ui.primaryColor||'#b8965a')+'</span></div>'+
    '<div>🔤 الخط: <span style="color:var(--gold)">'+escHtml(ui.fontFamily||'Tajawal')+'</span></div>'+
    '<div>📑 الأقسام: <span style="color:var(--gold)">'+s.length+' قسم</span></div>'+
    '<div>📄 الصفحات: <span style="color:var(--gold)">'+p.length+' صفحة</span></div>'+
    '<div>📱 واتساب: <span style="color:var(--gold)">'+(soc.whatsapp||'غير محدد')+'</span></div>';
}

function checkRekazStatus(){
  fetch(B+'/products')
    .then(function(r){
      var dot=document.getElementById('rekaz-dot');
      var txt=document.getElementById('rekaz-status');
      if(r.ok){dot.classList.add('live');txt.textContent='متصل ويعمل';}
      else{txt.textContent='خطأ في الاتصال';}
    })
    .catch(function(){document.getElementById('rekaz-status').textContent='غير متصل';});
}

// ── HELPERS ──
function closeModal(id){document.getElementById(id).classList.remove('on');}
function escHtml(s){return (s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}
</script>
</body>
</html>
